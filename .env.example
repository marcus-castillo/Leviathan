# --- Database ---
POSTGRES_USER=leviathan
POSTGRES_PASSWORD=leviathan
POSTGRES_DB=leviathan
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://leviathan:leviathan@db:5432/leviathan

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- NLP / models ---
SPACY_MODEL=en_core_web_sm
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OUTCOME_MODEL_PATH=  # leave blank to use the rule-based fallback classifier

# --- Ethics guardrails ---
MIN_SAMPLE_SIZE=30            # below this, no point estimates / rankings are returned
CONFIDENCE_LEVEL=0.95
FDR_ALPHA=0.05               # Benjamini-Hochberg false-discovery-rate target

# --- External data ---
COURTLISTENER_API_TOKEN=     # optional; raises rate limits for ingestion
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
